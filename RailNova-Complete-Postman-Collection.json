							"raw": "{{baseUrl}}/trains",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"trains"
							]
						},
						"description": "Get list of all trains"
					},
					"response": []
				},
				{
					"name": "Get Train with Fare",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/trains/{{trainId}}/fare?coachType=AC",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"trains",
								"{{trainId}}",
								"fare"
							],
							"query": [
								{
									"key": "coachType",
									"value": "AC"
								}
							]
						},
						"description": "Get train details with fare information"
					},
					"response": []
				},
				{
					"name": "Book Seat",
					"request": {
						"method": "PUT",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/trains/seats/{{seatId}}/book",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"trains",
								"seats",
								"{{seatId}}",
								"book"
							]
						},
						"description": "Book a specific seat (internal use by booking service)"
					},
					"response": []
				}
			],
			"description": "Train management endpoints"
		},
