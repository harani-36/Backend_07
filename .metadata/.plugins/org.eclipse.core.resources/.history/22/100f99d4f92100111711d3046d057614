package com.fare.dto;

import lombok.Getter;
import lombok.Setter;

@Getter
@Setter
public class FareResponse {

    private Long trainId;
    private String coachType;
    private Double baseFare;   // static price stored in DB
    private Double amount;      // final dynamic price (baseFare × multiplier)
    private String priceLabel;  // e.g. "High Demand", "Early Bird Discount"

    public FareResponse(Long trainId, String coachType, Double baseFare, Double amount, String priceLabel) {
        this.trainId = trainId;
        this.coachType = coachType;
        this.baseFare = baseFare;
        this.amount = amount;
        this.priceLabel = priceLabel;
    }
}