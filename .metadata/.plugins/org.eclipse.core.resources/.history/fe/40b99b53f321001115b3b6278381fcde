package com.fare.service.impl;

import java.time.LocalDate;
import java.time.temporal.ChronoUnit;
import java.util.List;

import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.fare.dto.FareRequest;
import com.fare.dto.FareResponse;
import com.fare.entity.Fare;
import com.fare.exception.ResourceNotFoundException;
import com.fare.repository.FareRepository;
import com.fare.service.DynamicPricingService;
import com.fare.service.FareService;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@Service
@RequiredArgsConstructor
@Slf4j
public class FareServiceImpl implements FareService {
    private final FareRepository fareRepository;
    private final DynamicPricingService dynamicPricingService;
    private final RestTemplate restTemplate = new RestTemplate();
    
    @Override
    public FareResponse addFare(FareRequest request) {
        log.info("Adding fare for train ID: {}, coach type: {}", request.getTrainId(), request.getCoachType());
        Fare fare = new Fare();
        fare.setTrainId(request.getTrainId());
        fare.setCoachType(request.getCoachType());
        fare.setBaseFare(request.getAmount());
        Fare saved = fareRepository.save(fare);
        return new FareResponse(saved.getTrainId(), saved.getCoachType(), saved.getBaseFare(), saved.getBaseFare(), "Normal Pricing");
    }

    @Override
    public FareResponse getFare(Long trainId, String coachType) {
        return getFareForDate(trainId, coachType, LocalDate.now().plusDays(1));
    }
    
    public FareResponse getFareForDate(Long trainId, String coachType, LocalDate journeyDate) {
        log.info("Fetching fare for train ID: {}, coach type: {}, date: {}", trainId, coachType, journeyDate);
        
        try {
            Fare fare = fareRepository
                    .findByTrainIdAndCoachType(trainId, coachType)
                    .orElseThrow(() -> {
                        log.error("Fare not found for train ID: {}, coach type: {}", trainId, coachType);
                        return new ResourceNotFoundException("Fare not found for train " + trainId + " and coach type " + coachType);
                    });
            
            // Get seat availability for dynamic pricing
            int availableSeats = getAvailableSeats(trainId, coachType, journeyDate);
            int totalSeats = getTotalSeats(trainId, coachType);
            int daysUntilJourney = (int) ChronoUnit.DAYS.between(LocalDate.now(), journeyDate);
            
            double multiplier = dynamicPricingService.calculateMultiplier(availableSeats, totalSeats, daysUntilJourney);
            Double dynamicFare = Math.round(fare.getBaseFare() * multiplier * 100.0) / 100.0;
            String priceLabel = dynamicPricingService.getSurgeLevel(multiplier);

            log.debug("Fare - Base: {}, Multiplier: {}, Final: {} for train {}, coach {}",
                     fare.getBaseFare(), multiplier, dynamicFare, trainId, coachType);

            return new FareResponse(fare.getTrainId(), fare.getCoachType(), fare.getBaseFare(), dynamicFare, priceLabel);
        } catch (Exception e) {
            log.error("Error fetching fare for train {}, coach {}: {}", trainId, coachType, e.getMessage());
            throw new ResourceNotFoundException("Unable to fetch fare: " + e.getMessage());
        }
    }
    
    @Override
    public List<String> getAvailableCoachTypes(Long trainId) {
        log.info("Fetching available coach types for train ID: {}", trainId);
        try {
            List<String> coachTypes = fareRepository.findCoachTypesByTrainId(trainId);
            log.debug("Found {} coach types for train ID: {}", coachTypes.size(), trainId);
            return coachTypes;
        } catch (Exception e) {
            log.error("Error fetching coach types for train {}: {}", trainId, e.getMessage());
            throw new ResourceNotFoundException("Unable to fetch coach types: " + e.getMessage());
        }
    }
    
    private int getAvailableSeats(Long trainId, String coachType, LocalDate journeyDate) {
        try {
            // Call train service to get available seats
            String url = "http://localhost:8082/seats/available?trainId=" + trainId + 
                        "&coachType=" + coachType + "&date=" + journeyDate;
            Integer seats = restTemplate.getForObject(url, Integer.class);
            return seats != null ? seats : 50; // Default fallback
        } catch (Exception e) {
            log.warn("Could not fetch seat availability, using default: {}", e.getMessage());
            return 50; // Default fallback
        }
    }
    
    private int getTotalSeats(Long trainId, String coachType) {
        try {
            // Call train service to get total seats
            String url = "http://localhost:8082/coaches/total-seats?trainId=" + trainId + 
                        "&coachType=" + coachType;
            Integer seats = restTemplate.getForObject(url, Integer.class);
            return seats != null ? seats : 72; // Default fallback
        } catch (Exception e) {
            log.warn("Could not fetch total seats, using default: {}", e.getMessage());
            return 72; // Default fallback
        }
    }
}